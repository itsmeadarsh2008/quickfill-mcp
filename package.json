{
  "name": "@dikshitrj/quickfill-mcp",
  "version": "1.0.15",
  "description": "Quickfill MCP Server: Hot-reloading Alpine.js environment for local file parsing.",
  "author": "DikshitRJ",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "alpinejs",
    "interactive"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "quickfill-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "express": "^4.18.2",
    "get-port": "^7.0.0",
    "open": "^10.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "javascript-obfuscator": "^5.4.2",
    "prettier": "^3.8.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DikshitRJ/quickfill-mcp.git"
  }
}
